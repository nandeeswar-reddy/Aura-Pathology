# Environment Mode (development or production)
APP_ENV=production

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Secret Key for JWT Authentication (change this in production!)
SECRET_KEY=your_super_secret_key_here

# Optional: Directory for uploads (defaults to backend/uploads)
# UPLOADS_DIR=/path/to/persistent/storage/uploads

# Optional: Path for database (defaults to backend/database.db)
# DB_PATH=/path/to/persistent/storage/database.db
